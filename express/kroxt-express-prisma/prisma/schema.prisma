generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id
  email         String   @unique
  passwordHash  String
  name          String?
  title         String?
  dob           String?
  stateOfOrigin String?
  phoneNumber   String?
  role          String   @default("user")
  schoolId      String?
  age           Int?
  gender        String?
  oauthProvider String?
  oauthId       String?
  createdAt     DateTime @default(now())
}

model RateLimit {
  key       String @id
  count     Int
  resetTime Float
}
