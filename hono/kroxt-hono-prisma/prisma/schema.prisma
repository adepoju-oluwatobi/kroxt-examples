generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  name          String?
  title         String?
  age           Int?
  gender        String?
  dob           String?
  stateOfOrigin String?
  phoneNumber   String?
  role          String?  @default("user")
  schoolId      String?
  createdAt     DateTime @default(now())
}
